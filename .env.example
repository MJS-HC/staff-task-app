# Production Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Staging Firebase Configuration (optional)
# Uncomment these and replace with your staging Firebase credentials to test in staging
# VITE_STAGING_FIREBASE_API_KEY=your_staging_api_key
# VITE_STAGING_FIREBASE_AUTH_DOMAIN=your_staging_project.firebaseapp.com
# VITE_STAGING_FIREBASE_PROJECT_ID=your_staging_project_id
# VITE_STAGING_FIREBASE_STORAGE_BUCKET=your_staging_project.appspot.com
# VITE_STAGING_FIREBASE_MESSAGING_SENDER_ID=your_staging_sender_id
# VITE_STAGING_FIREBASE_APP_ID=your_staging_app_id
